#!/bin/bash

# Check if at least one file is provided
if [ "$#" -eq 0 ]; then
  echo "Usage: fixframe.sh <video-files>"
  exit 1
fi

for input in "$@"; do
  # Extract filename without extension
  filename="${input%.*}"
  extension="${input##*.}"

  # Set output filename
  output="${filename}_fixed.${extension}"

  echo "Processing $input..."

  ffmpeg -i "$input" -vf fps=30 "$output"

  mv "$output" "$input"
done

echo "Done!"
