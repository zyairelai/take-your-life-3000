#!/bin/bash

# Check if input file is provided
if [ -z "$1" ]; then
  echo "Usage: fixframe <input-video>"
  exit 1
fi

input="$1"

# Extract filename without extension
filename="${input%.*}"
extension="${input##*.}"

# Set output filename
output="${filename}_fixed.${extension}"

# Run ffmpeg
ffmpeg -i "$input" -vf fps=30 "$output"

echo "Created: $output"
