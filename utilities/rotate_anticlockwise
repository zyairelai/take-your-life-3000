#!/bin/bash

# Check if at least one file is provided
if [ "$#" -eq 0 ]; then
  echo "Usage: rotateanticlockwise.sh <input-videos>"
  exit 1
fi

for input in "$@"; do
  # Extract filename and extension
  filename="${input%.*}"
  extension="${input##*.}"

  # Output file name
  output="${filename}_rotated.${extension}"

  echo "Processing $input..."

  # Rotate 90° anticlockwise
  ffmpeg -i "$input" -vf "transpose=2" "$output"

  echo "Created: $output"
done

echo "Done!"
